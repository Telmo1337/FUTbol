# Copy this file to `.dev.vars` and fill in your real values.
# `.dev.vars` is gitignored — it never gets committed.

# Discord bot token (Developer Portal → your app → Bot → Reset Token). SECRET.
# Needed to send messages (and by `npm run register`).
DISCORD_BOT_TOKEN=

# Discord application public key (Developer Portal → General Information).
# Verifies that incoming interactions really came from Discord.
DISCORD_PUBLIC_KEY=

# Discord application id (General Information). Used to register slash commands.
DISCORD_APPLICATION_ID=

# Your server (guild) id. Enable Developer Mode in Discord, then right-click the
# server → Copy Server ID. Used by `npm run register`.
DISCORD_GUILD_ID=

# Your Discord user id(s), comma-separated — the admins who can run /novojogo,
# /fecharvotacao and /cancelar. Right-click your name → Copy User ID (or use /euquem).
ADMIN_IDS=

# Channel where the weekly auto-game poll is posted (Sunday 18:00). Right-click the
# channel → Copy Channel ID. Leave empty to disable the weekly auto-game.
GAME_CHANNEL_ID=
