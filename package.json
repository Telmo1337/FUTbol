{
  "name": "futbol-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Discord bot for organising a weekly casual football game (pt-PT).",
  "scripts": {
    "selftest": "tsx scripts/selftest.ts",
    "register": "tsx scripts/register-commands.ts",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply futbol-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply futbol-db --remote",
    "db:tables": "wrangler d1 execute futbol-db --local --command \"SELECT name FROM sqlite_master WHERE type='table' ORDER BY name\""
  },
  "dependencies": {
    "drizzle-orm": "^0.38.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "wrangler": "^4.101.0"
  }
}
